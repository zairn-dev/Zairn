# GeoDropRegistryV2 Deployment Configuration
# Copy this file to .env and fill in the values.

# JSON-RPC endpoint for the target network
# Base Sepolia:    https://sepolia.base.org
# Polygon Amoy:    https://rpc-amoy.polygon.technology
# Arbitrum Sepolia: https://sepolia-rollup.arbitrum.io/rpc
RPC_URL=https://sepolia.base.org

# Deployer wallet private key (hex, with or without 0x prefix)
# WARNING: Never commit this value to version control.
PRIVATE_KEY=

# Address to set as the proxy admin (controls upgrades)
# Use a multisig or dedicated admin wallet in production.
ADMIN_ADDRESS=

# Human-readable network label (saved in deployment output)
CHAIN_NAME=base-sepolia
