{
  "name": "@zairn/geo-drop",
  "version": "0.1.0",
  "description": "Location-bound decentralized data drops with IPFS and geofence verification",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
