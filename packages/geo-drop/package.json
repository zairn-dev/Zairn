{
  "name": "@zairn/geo-drop",
  "version": "0.1.0",
  "description": "Location-bound decentralized data drops with IPFS and geofence verification",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "zkp:compile": "powershell -ExecutionPolicy Bypass -File ./circuits/build-zairn-zkp.ps1 -CompileOnly",
    "zkp:build": "powershell -ExecutionPolicy Bypass -File ./circuits/build-zairn-zkp.ps1",
    "zkp:witness": "node ./circuits/run-witness.cjs ./circuits/build/zairn_zkp_js/zairn_zkp.wasm ./circuits/example-zairn-zkp-input.json ./circuits/build/zairn_zkp.wtns",
    "zkp:prove": "snarkjs groth16 prove ./circuits/zairn_zkp_final.zkey ./circuits/build/zairn_zkp.wtns ./circuits/build/zairn_zkp_proof.json ./circuits/build/zairn_zkp_public.json",
    "zkp:verify": "snarkjs groth16 verify ./circuits/verification_key.json ./circuits/build/zairn_zkp_public.json ./circuits/build/zairn_zkp_proof.json",
    "zkp:bench": "node ./test/benchmark-zkp.mjs",
    "zkp:evaluate": "node ./test/evaluate-zairn-zkp.mjs",
    "zkp:paper-eval": "node ./test/evaluate-regular-paper.mjs",
    "zkp:boundary": "node ./test/evaluate-boundary-cases.mjs",
    "zkp:boundary:sweep": "node ./test/evaluate-boundary-sweep.mjs",
    "zkp:latency": "node ./test/evaluate-unlock-latency.mjs",
    "zkp:endtoend": "node ./test/evaluate-end-to-end.mjs",
    "zkp:repro": "node ./test/reproducibility-check.mjs",
    "zkp:prototype:bench": "node ./test/prototype-bench.mjs",
    "zkp:prototype:latency": "node ./test/prototype-latency.mjs",
    "zkp:off-circuit": "node ./test/evaluate-off-circuit-baseline.mjs",
    "zkp:defense": "node ./test/evaluate-defense-in-depth.mjs",
    "zkp:browser:serve": "npx serve . -p 3456 -C",
    "zkp:test": "tsx test/verify-features.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0"
  },
  "devDependencies": {
    "circom2": "^0.2.22",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "@zairn/sdk": "workspace:*"
  },
  "peerDependenciesMeta": {
    "snarkjs": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "snarkjs": "^0.7.0"
  },
  "author": "Zairn Contributors",
  "keywords": [
    "location",
    "geofence",
    "ipfs",
    "web3",
    "nft",
    "decentralized"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zairn-dev/Zairn.git",
    "directory": "packages/geo-drop"
  }
}
